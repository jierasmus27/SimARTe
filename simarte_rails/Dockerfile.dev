FROM ruby:3.4-slim

# Install system dependencies for Rails + Postgres + Redis + Node
RUN apt-get update -qq && apt-get install -y \
    build-essential \
    libpq-dev \
    libyaml-dev \
    pkg-config \
    nodejs \
    git \
    curl \
    imagemagick \
    libxml2-dev \
    libxslt-dev \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Install bundler
RUN gem install bundler

# Copy only Gemfile and Gemfile.lock first for caching
COPY Gemfile Gemfile.lock ./

# Install gems
RUN bundle install --jobs 4 --retry 3

# Copy the rest of the app
COPY . .

# Expose Rails default port
EXPOSE 3000

# Fix Rails PID issue and start server
CMD ["bash", "-c", "rm -f tmp/pids/server.pid && bin/rails server -b 0.0.0.0"]
