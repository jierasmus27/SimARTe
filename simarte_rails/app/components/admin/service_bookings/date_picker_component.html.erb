<section class="relative">
  <%= hidden_field_tag field_name, selected_date, id: "service_date" %>

  <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
    <div class="glass-panel wireframe-bracket rounded-xl border border-outline-variant/10 bg-surface-container p-8 lg:col-span-7">
      <div class="mb-8 flex items-center justify-between">
        <button type="button" class="p-2 text-primary transition-all hover:bg-primary/10" aria-label="Previous month">
          <span class="material-symbols-outlined" aria-hidden="true">arrow_back_ios</span>
        </button>
        <div class="text-center">
          <div class="text-xl font-bold uppercase tracking-widest text-primary">October</div>
          <div class="font-label text-[0.625rem] text-on-surface-variant">YEAR_2024</div>
        </div>
        <button type="button" class="p-2 text-primary transition-all hover:bg-primary/10" aria-label="Next month">
          <span class="material-symbols-outlined" aria-hidden="true">arrow_forward_ios</span>
        </button>
      </div>

      <div class="mb-4 grid grid-cols-7 gap-1 text-center font-label text-[0.625rem] uppercase tracking-widest text-on-surface-variant">
        <div>Mon</div>
        <div>Tue</div>
        <div>Wed</div>
        <div>Thu</div>
        <div>Fri</div>
        <div>Sat</div>
        <div>Sun</div>
      </div>

      <div class="grid grid-cols-7 gap-2">
        <% unselectable_start_days.each do |date| %>
          <div class="flex aspect-square items-center justify-center text-xs opacity-20"><%= date.day %></div>
        <% end %>

        <% selectable_days_of_month.each do |date| %>
          <% if date.day == selected_date.day %>
            <button type="button" class="flex aspect-square items-center justify-center bg-primary text-xs font-bold text-on-primary shadow-[0_0_20px_rgba(172,234,211,0.4)]">
              <%= date.day.to_s %>
            </button>
          <% else %>
            <button type="button" class="flex aspect-square cursor-pointer items-center justify-center text-xs transition-all hover:bg-primary/10">
              <%= date.day.to_s %>
            </button>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</section>
