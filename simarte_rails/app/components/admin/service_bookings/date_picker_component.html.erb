<section class="relative">
  <%= hidden_field_tag field_name, selected_date, id: "service_date" %>

  <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
    <div class="glass-panel wireframe-bracket rounded-xl border border-outline-variant/10 bg-surface-container p-8 lg:col-span-7">
      <div class="mb-8 flex items-center justify-between">
        <% if previous_month_selectable? %>
          <%= link_to date_picker_path(previous_month_date),
            class: "p-2 text-primary transition-all hover:bg-primary/10",
            data: { turbo_frame: "service_booking_date_picker" },
            aria: { label: "Previous month" } do %>
            <span class="material-symbols-outlined" aria-hidden="true">arrow_back_ios</span>
          <% end %>
        <% else %>
          <span class="p-2 text-primary/30" aria-label="Previous month unavailable">
            <span class="material-symbols-outlined" aria-hidden="true">arrow_back_ios</span>
          </span>
        <% end %>
        <div class="text-center">
          <div class="text-xl font-bold uppercase tracking-widest text-primary"><%= current_month_label %></div>
          <div class="font-label text-[0.625rem] text-on-surface-variant"><%= current_year_label %></div>
        </div>
        <%= link_to date_picker_path(next_month_date),
          class: "p-2 text-primary transition-all hover:bg-primary/10",
          data: { turbo_frame: "service_booking_date_picker" },
          aria: { label: "Next month" } do %>
          <span class="material-symbols-outlined" aria-hidden="true">arrow_forward_ios</span>
        <% end %>
      </div>

      <div class="mb-4 grid grid-cols-7 gap-1 text-center font-label text-[0.625rem] uppercase tracking-widest text-on-surface-variant">
        <div>Mon</div>
        <div>Tue</div>
        <div>Wed</div>
        <div>Thu</div>
        <div>Fri</div>
        <div>Sat</div>
        <div>Sun</div>
      </div>

      <div class="grid grid-cols-7 gap-2">
        <% unselectable_start_days.each do |date| %>
          <div class="flex aspect-square items-center justify-center text-xs opacity-20"><%= date.day %></div>
        <% end %>

        <% selectable_days_of_month.each do |date| %>
          <%= link_to date.day.to_s, date_picker_path(date), date_link_options(date) %>
        <% end %>
      </div>
    </div>
  </div>
</section>
