<aside
  class="fixed top-0 left-0 z-50 flex h-screen w-64 -translate-x-full flex-col border-r border-[#141618] bg-[#111416] transition-transform duration-200 md:static md:translate-x-0"
  data-sidebar-target="panel"
>
  <div class="flex h-full flex-col space-y-2 py-8">
    <div class="mb-4 px-8">
      <h1 class="font-headline text-xl font-black tracking-tighter text-primary">SimARTe</h1>
      <p class="mt-1 text-[10px] font-medium tracking-[0.2em] text-on-surface-variant uppercase">Living Observatory</p>
    </div>

    <nav class="mt-8 flex-1 space-y-0.5">
      <%= link_to admin_dashboard_path, class: nav_class(admin_dashboard_path) do %>
        <span class="material-symbols-outlined text-xl transition-transform duration-300 group-hover:translate-x-1" data-icon="dashboard">dashboard</span>
        <span class="text-sm">Dashboard</span>
      <% end %>
      <%= link_to admin_users_path, class: nav_class(admin_users_path) do %>
        <span class="material-symbols-outlined text-xl transition-transform duration-300 group-hover:translate-x-1" data-icon="group">group</span>
        <span class="text-sm">Users</span>
      <% end %>
      <%= link_to admin_services_path, class: nav_class(admin_services_path) do %>
        <span class="material-symbols-outlined text-xl transition-transform duration-300 group-hover:translate-x-1" data-icon="layers">layers</span>
        <span class="text-sm">Services</span>
      <% end %>
      <%= link_to admin_analytics_path, class: nav_class(admin_analytics_path) do %>
        <span class="material-symbols-outlined text-xl transition-transform duration-300 group-hover:translate-x-1" data-icon="query_stats">query_stats</span>
        <span class="text-sm">Analytics</span>
      <% end %>
      <%= link_to admin_settings_path, class: nav_class(admin_settings_path) do %>
        <span class="material-symbols-outlined text-xl transition-transform duration-300 group-hover:translate-x-1" data-icon="settings">settings</span>
        <span class="text-sm">Settings</span>
      <% end %>
    </nav>

    <div class="mt-auto space-y-1 border-t border-[#141618] px-8 pt-8">
      <button type="button" class="mb-6 flex w-full items-center justify-center gap-2 rounded-sm bg-primary py-2.5 font-headline text-sm font-bold text-[#0c0e10] transition active:scale-95">
        <span class="material-symbols-outlined text-lg text-[#0c0e10]" data-icon="add">add</span>
        New Simulation
      </button>
      <a class="flex items-center gap-3 py-2 font-headline font-medium text-on-surface/50 transition hover:text-primary" href="#">
        <span class="material-symbols-outlined text-xl" data-icon="contact_support">contact_support</span>
        <span class="text-sm">Support</span>
      </a>
      <a class="flex items-center gap-3 py-2 font-headline font-medium text-on-surface/50 transition hover:text-primary" href="#">
        <span class="material-symbols-outlined text-xl" data-icon="menu_book">menu_book</span>
        <span class="text-sm">Documentation</span>
      </a>
    </div>
  </div>
</aside>
