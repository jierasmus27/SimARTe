<header class="sticky top-0 z-30 border-b border-[#141618] bg-[#0c0e10]/70 backdrop-blur-3xl">
  <div class="flex w-full items-center justify-between px-4 py-4 sm:px-8">
    <div class="flex items-center gap-4">
      <button
        type="button"
        class="text-primary md:hidden"
        data-action="click->sidebar#open"
        aria-label="Open menu"
      >
        <span class="material-symbols-outlined" data-icon="menu">menu</span>
      </button>
      <div class="font-headline text-sm font-semibold text-on-surface sm:text-base">
        SimARTe
        <span class="hidden text-on-surface-variant sm:inline"> — Living Observatory</span>
      </div>
    </div>

    <div class="flex items-center gap-4 sm:gap-6">
      <div class="relative" data-controller="dropdown">
        <button
          type="button"
          class="text-on-surface/60 transition hover:text-primary active:scale-95"
          data-action="click->dropdown#toggle"
          aria-expanded="false"
          aria-label="Notifications"
        >
          <span class="material-symbols-outlined" data-icon="notifications">notifications</span>
        </button>
        <div
          class="absolute right-0 z-50 mt-2 hidden min-w-[12rem] rounded-sm border border-outline-variant/15 bg-surface-container py-2 shadow-lg"
          data-dropdown-target="menu"
        >
          <p class="px-4 py-3 text-sm text-on-surface-variant">No notifications</p>
        </div>
      </div>

      <a class="text-on-surface/60 transition hover:text-primary active:scale-95" href="#" aria-label="Help">
        <span class="material-symbols-outlined" data-icon="help_outline">help_outline</span>
      </a>

      <div class="relative" data-controller="dropdown">
        <button
          type="button"
          class="flex h-8 w-8 items-center justify-center rounded-sm bg-surface-container-high font-headline text-xs font-bold text-primary ring-1 ring-outline-variant/20"
          data-action="click->dropdown#toggle"
          aria-expanded="false"
          aria-label="Account menu"
        >
          <%= user.initials %>
        </button>
        <div
          class="absolute right-0 z-50 mt-2 hidden min-w-[10rem] rounded-sm border border-outline-variant/15 bg-surface-container py-1 shadow-lg"
          data-dropdown-target="menu"
        >
          <%= button_to "Log out", destroy_user_session_path, method: :delete,
                class: "w-full px-4 py-2 text-left text-sm text-on-surface hover:bg-surface-container-high",
                form: { data: { turbo: false } } %>
        </div>
      </div>
    </div>
  </div>
</header>
