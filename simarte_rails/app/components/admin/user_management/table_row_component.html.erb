<tr
  id="<%= dom_id(user, :table_row) %>"
  class="hover:bg-primary/5 transition-colors group"
  data-user-id="<%= user.id %>"
>
  <td class="px-6 py-5">
    <div class="flex items-center gap-4">
      <div
        class="w-10 h-10 rounded-sm bg-surface-container-highest flex items-center justify-center border border-outline-variant/10">
        <span class="material-symbols-outlined text-primary/80"
          data-icon="account_circle">account_circle</span>
      </div>
      <div>
        <div class="text-sm font-medium text-on-surface"><%= user.full_name %></div>
        <div class="text-xs text-on-surface-variant font-['Space_Grotesk']"><%= user.email %></div>
      </div>
    </div>
  </td>
  <td class="px-6 py-5">
    <%= form_with(
      model: user,
      url: admin_user_path(user),
      method: :put,
      data: {
        controller: "auto-submit",
        action: "selected->auto-submit#submit"
      },
      class: "inline-flex justify-center"
    ) do |f| %>
      <%= render Form::SelectModalComponent.new(
        form: f,
        attribute: :role,
        selected_value: user.role,
        options: User.roles.keys.sort,
        header: "Select Operational Role"
      ) %>
    <% end %>
  </td>
  <% services.each do |service| %>
    <td
      class="px-6 py-5 text-center"
      data-service-id="<%= service.id %>"
      data-user-id="<%= user.id %>"
    >
      <% if (sub = subscription_for(service)) %>
        <%= form_with url: admin_subscription_path(sub), method: :delete, data: { turbo: true, controller: "subscription-toggle" }, class: "inline-flex justify-center" do %>
          <label class="relative inline-flex cursor-pointer items-center">
            <input
              type="checkbox"
              class="sr-only peer"
              checked
              id="subscription_<%= user.id %>_service_<%= service.id %>"
              data-action="change->subscription-toggle#submitIfUnchecked"
            />
            <div
              class="w-8 h-4 bg-surface-container-lowest rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-on-surface-variant after:border-none after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-primary peer-checked:after:bg-[#0c0e10]">
            </div>
          </label>
        <% end %>
      <% else %>
        <%= form_with url: admin_subscriptions_path, method: :post, data: { turbo: true, controller: "subscription-toggle" }, class: "inline-flex justify-center" do %>
          <%= hidden_field_tag :user_id, user.id %>
          <%= hidden_field_tag :service_id, service.id %>
          <label class="relative inline-flex cursor-pointer items-center">
            <input
              type="checkbox"
              class="sr-only peer"
              id="subscription_<%= user.id %>_service_<%= service.id %>"
              data-action="change->subscription-toggle#submitIfChecked"
            />
            <div
              class="w-8 h-4 bg-surface-container-lowest rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-on-surface-variant after:border-none after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-primary peer-checked:after:bg-[#0c0e10]">
            </div>
          </label>
        <% end %>
      <% end %>
    </td>
  <% end %>
  <td class="px-6 py-5 text-right">
    <div class="flex justify-end gap-1">
      <button type="button" class="p-2 text-on-surface-variant hover:text-primary transition-colors"
        title="Reset Password">
        <span class="material-symbols-outlined text-lg" data-icon="lock_reset">lock_reset</span>
      </button>
      <button type="button" class="p-2 text-on-surface-variant hover:text-primary transition-colors"
        title="Edit Permissions">
        <span class="material-symbols-outlined text-lg" data-icon="shield_person">shield_person</span>
      </button>
    </div>
  </td>
</tr>
