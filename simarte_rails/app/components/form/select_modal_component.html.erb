<div data-controller="select-modal">
  <button
    type="button"
    data-action="click->select-modal#open">
    <span
      class="cursor-pointer inline-flex items-center px-2 py-0.5 rounded-sm text-[10px] font-bold uppercase tracking-tight bg-primary/10 text-primary border border-primary/20 font-['Space_Grotesk']">
      <div data-select-modal-target="selectedLabel"><%= helpers.highlight_search(selected_value.humanize, search_query) %></div>
    </span>
  </button>

  <%= render Ui::ModalFrameComponent.new(
    variant: :glass,
    overlay_extra_class: "hidden",
    overlay_html_attributes: {
      data: {
        select_modal_target: "background",
        action: "click->select-modal#dismissBackground"
      }
    },
    panel_html_attributes: {
      data: { select_modal_target: "content" }
    }
  ) do %>
    <button
      class="cursor-pointer absolute top-6 right-6 w-8 h-8 flex items-center justify-center rounded-full bg-primary/10 border border-primary/20 text-primary hover:bg-primary/20 hover:scale-110 transition-all duration-200 z-[110]"
      data-action="click->select-modal#dismiss"
      aria-label="Close"
      type="button"
    >
      <span class="material-symbols-outlined text-lg font-bold">close</span>
    </button>
    <!-- Modal Header -->
    <div class="mb-8 text-center">
      <div class="inline-flex items-center justify-center w-12 h-12 bg-primary/10 rounded-xl mb-4 border border-primary/20">
        <span class="material-symbols-outlined text-primary text-2xl">admin_panel_settings</span>
      </div>
      <h2 class="text-2xl font-bold font-headline tracking-tight text-on-surface"><%= header %></h2>
      <p class="text-on-surface-variant text-sm mt-1">Assign system permissions and interface layout</p>
    </div>
    <!-- Role List -->
    <div class="space-y-3">
      <%= hidden_field_tag(
        field_name,
        selected_value,
        id: field_id,
        data: { select_modal_target: "selectedValue" }
      ) %>
      <% options.each do |option| %>
        <div class="group flex items-center justify-between p-4 rounded-xl bg-surface-container-highest/50 border border-outline-variant/10 hover:border-primary/40 hover:bg-primary/5 transition-all cursor-pointer"
          data-select-modal-target="option"
          data-action="click->select-modal#selectOption"
          data-option-value="<%= option %>"
        >
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-surface-container-highest flex items-center justify-center text-on-surface-variant group-hover:text-primary transition-colors">
              <span class="material-symbols-outlined">construction</span>
            </div>
            <div>
              <p class="text-sm font-bold tracking-wide"><%= helpers.highlight_search(option.humanize, search_query) %></p>
              <p class="text-[12px] text-on-surface-variant tracking-tighter"><%= t("activerecord.attributes.user.role.descriptions.#{option}") %></p>
            </div>
          </div>
          <% if option == selected_value %>
            <div class="flex items-center gap-2">
              <span class="text-[10px] font-bold text-primary uppercase tracking-widest">Active</span>
              <span class="material-symbols-outlined text-primary">check_circle</span>
            </div>
          <% else %>
            <span class="material-symbols-outlined text-on-surface-variant/30 group-hover:text-primary">arrow_forward_ios</span>
          <% end %>
        </div>
      <% end %>
    </div>
    <!-- Absolute Corner Decorations -->
    <div class="absolute top-0 left-0 w-8 h-8 border-t border-l border-primary/20 rounded-tl-[24px]"></div>
    <div class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-primary/20 rounded-br-[24px]"></div>
  <% end %>
</div>
