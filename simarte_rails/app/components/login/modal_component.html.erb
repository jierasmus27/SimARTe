<div data-controller="modal" class="relative w-full">
  <div class="glass-panel border border-primary/10 p-10 rounded-sm shadow-[0_40px_100px_rgba(0,0,0,0.5)] relative">

    <button
      type="button"
      class="absolute top-4 right-4 flex h-9 w-9 items-center justify-center rounded-sm text-on-surface/50 transition hover:bg-white/5 hover:text-on-surface"
      data-action="click->modal#close"
      aria-label="Close"
    >
      <span class="material-symbols-outlined text-xl leading-none">close</span>
    </button>

    <header class="mb-10 text-center">
      <h2 class="font-headline text-2xl font-bold text-on-surface mb-2 tracking-tight">
        <%= title %>
      </h2>
      <div class="h-[2px] w-8 bg-primary mx-auto mb-4"></div>
      <p class="text-xs text-on-surface/50 font-medium uppercase tracking-wider">
        Identity Verification Protocol
      </p>
    </header>

    <% if (alert_msg = alert_message).present? %>
      <div
        role="alert"
        class="mb-6 rounded-sm border border-error/40 bg-error/10 px-4 py-3 text-center text-sm text-error"
      >
        <%= alert_msg %>
      </div>
    <% end %>

    <%= form_with url: user_session_path, scope: :user, method: :post, class: "space-y-8", data: { turbo: false } do |f| %>

      <div class="space-y-2">
        <%= f.label :email, "Registry ID",
          class: "font-headline text-[10px] font-bold uppercase tracking-widest text-primary" %>

        <div class="relative group">
          <%= f.email_field :email,
            autocomplete: "email",
            class: "login-field font-body relative z-0 w-full bg-[#060708] border border-white/5 py-4 pl-12 pr-4 text-on-surface placeholder:text-on-surface/45 focus:text-on-surface focus:outline-none focus:ring-1 focus:ring-primary/40 rounded-sm",
            placeholder: "your.email@example.com" %>
          <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 z-10 -translate-y-1/2 text-primary/70 group-focus-within:text-primary" aria-hidden="true">
            person
          </span>
        </div>
      </div>

      <div class="space-y-2">
        <%= f.label :password, "Encryption Key",
          class: "font-headline text-[10px] font-bold uppercase tracking-widest text-primary" %>

        <div class="relative group">
          <%= f.password_field :password,
            autocomplete: "current-password",
            class: "login-field font-body relative z-0 w-full bg-[#060708] border border-white/5 py-4 pl-12 pr-12 text-on-surface placeholder:text-on-surface/45 focus:text-on-surface focus:outline-none focus:ring-1 focus:ring-primary/40 rounded-sm",
            placeholder: "••••••••••••" %>
          <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 z-10 -translate-y-1/2 text-primary/70 group-focus-within:text-primary" aria-hidden="true">
            lock
          </span>
        </div>
      </div>

      <%= f.button "INITIALIZE SESSION",
        type: :submit,
        class: "w-full cursor-pointer border-0 bg-primary px-4 py-5 font-headline text-base font-black text-[#0c0e10] shadow-sm transition hover:opacity-95 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/60 focus-visible:ring-offset-0 active:opacity-90 rounded-sm" %>

    <% end %>

  </div>
</div>
