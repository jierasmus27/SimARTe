<section class="space-y-3 w-full min-w-0 lg:col-span-7">
  <div class="<%= "hidden" unless @selected_user_id.present? || params[:date].present? %>" data-service-booking-flow-target="calendar">
    <%= render Admin::ServiceBookings::DatePickerComponent.new(
      selected_date: @selected_date,
      field_name: "service_booking[date]",
      user_id: @selected_user_id
    ) %>
  </div>
</section>
<div class="w-full min-w-0 lg:col-span-5">
  <%= render Admin::ServiceBookings::AvailabilitySlotsComponent.new(
    service_booking_time_slots: @service_booking_time_slots,
    selected_date: @selected_date,
    selected_user_id: @selected_user_id
  ) %>
</div>
