<div class="px-6 sm:px-16 pt-10 pb-6">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-[10px] font-label uppercase tracking-[0.25em] text-primary/70">Service Bookings</p>
      <h2 class="mt-2 font-headline text-4xl font-bold tracking-tight text-on-surface">Book a Consultant Timeslot</h2>
      <p class="mt-3 max-w-2xl font-body leading-relaxed text-on-surface-variant">
        Select a client user, choose a calendar date, and review the open service windows for that day.
      </p>
    </div>
    <div class="flex items-center gap-3 rounded-sm border border-primary/15 bg-primary/5 px-4 py-3 text-xs font-bold uppercase tracking-widest text-primary">
      <span class="material-symbols-outlined text-lg" aria-hidden="true">event_available</span>
      Window Planner
    </div>
  </div>
</div>

<div class="px-6 sm:px-16 py-8">
  <div class="grid gap-6 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.25fr)]">
    <section class="space-y-6">
      <%= render Admin::ServiceBookings::UserSelectionComponent.new(users: @users, selected_user_id: @selected_user_id) %>
      <%= render Admin::ServiceBookings::DatePickerComponent.new(selected_date: @selected_date) %>
    </section>

    <%= render Admin::ServiceBookings::AvailabilitySlotsComponent.new(service_booking_time_slots: @service_booking_time_slots, selected_date: @selected_date) %>
  </div>
</div>
