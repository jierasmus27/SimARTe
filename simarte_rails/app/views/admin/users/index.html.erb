<div class="flex flex-col px-6 py-8 sm:px-16">
  <header class="mb-8">
    <h2 class="font-headline text-3xl font-bold tracking-tight text-on-surface sm:text-4xl">User Management</h2>
    <p class="mt-3 max-w-2xl leading-relaxed text-on-surface-variant">
      Manage system access and roles (static reference layout for v1).
    </p>
  </header>

  <div class="overflow-hidden rounded-sm border border-outline-variant/10 bg-surface-container shadow-none">
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-left">
        <thead>
          <tr class="bg-surface-container-low/30">
            <th class="px-6 py-4 text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant">Name</th>
            <th class="px-6 py-4 text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant">Email</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/5">
          <% @users.each do |u| %>
            <tr class="hover:bg-primary/5">
              <td class="px-6 py-4 text-sm font-medium text-on-surface"><%= u.first_name %> <%= u.last_name %></td>
              <td class="px-6 py-4 text-sm text-on-surface-variant"><%= u.email %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
